  "keyFeatures": [
    "Search countries by name or code",
    "View detailed country information including flags, capitals, and population",
    "Browse neighboring countries through border navigation",
    "Track search history with localStorage persistence",
    "Multilingual support (Spanish and English)"
  ],
  "publicApiSurface": [
    "getAll() - Fetch all countries",
    "getByName(name) - Fetch country by name",
    "useCountryInfo(name) - Hook for country details",
    "useCountry() - Hook for country context",
    "CountryProvider - Context provider component",
    "BuscadorCountry - Search component",
    "CountryInfo - Country details component",
    "BorderCountry - Border navigation component",
    "HistoryComponent - Search history component"
  ]
